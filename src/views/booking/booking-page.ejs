<%- include('../partials/header') %>

<section class="container page-section">
  <div class="section-head">
    <div>
      <p class="eyebrow">Booking Checkout</p>
      <h1>Confirm <%= type.toUpperCase() %> Reservation</h1>
    </div>
  </div>

  <div class="booking-layout">
    <article class="card-glass booking-summary reveal">
      <h3>Selected Option</h3>
      <% if (type === 'hotel') { %>
        <p><strong>Hotel:</strong> <%= item.hotel_name %></p>
        <p><strong>Room Type:</strong> <%= item.room_type %></p>
        <p><strong>Availability:</strong> <%= item.available_rooms %> / <%= item.total_rooms %> Rooms</p>
        <p><strong>Price:</strong> INR <%= item.price_per_night %> per night</p>
      <% } else { %>
        <p><strong>Operator:</strong> <%= item.operator_name %> (<%= item.code %>)</p>
        <p><strong>Date:</strong> <%= item.travel_date %></p>
        <p><strong>Time:</strong> <%= item.depart_time %> - <%= item.arrive_time %></p>
        <p><strong>Class:</strong> <%= item.class_type %></p>
        <p><strong>Availability:</strong> <%= item.available_seats %> / <%= item.total_seats %> Seats</p>
        <p><strong>Price:</strong> INR <%= item.price %> per seat</p>
      <% } %>
    </article>

    <form class="card-glass booking-form reveal" action="/booking/create" method="POST" id="bookingForm" novalidate>
      <input type="hidden" name="type" value="<%= type %>" />
      <input type="hidden" name="item_id" value="<%= item[type + '_id'] || item.hotel_id %>" />

      <h3>Passenger Information</h3>
      <label>Full Name
        <input name="passenger_name" required />
      </label>
      <label>Email
        <input type="email" name="passenger_email" required />
      </label>
      <label>Phone
        <input name="passenger_phone" pattern="\d{10}" required />
      </label>

      <% if (type !== 'hotel') { %>
        <label>Passenger Gender
          <select name="passenger_gender" id="passengerGender" required>
            <option value="">Select gender</option>
            <option value="MALE">Male</option>
            <option value="FEMALE">Female</option>
            <option value="OTHER">Other</option>
          </select>
        </label>
      <% } %>

      <div class="seat-map-shell">
        <div class="seat-map-head">
          <h4><%= type === 'hotel' ? 'Select Room(s)' : 'Select Seat(s)' %></h4>
          <div class="seat-legend">
            <span><i class="dot dot-available"></i>Available</span>
            <% if (type !== 'hotel') { %>
              <span><i class="dot dot-window"></i>Window</span>
              <span><i class="dot dot-lady"></i>Ladies Reserved</span>
            <% } %>
            <span><i class="dot dot-booked"></i>Reserved</span>
            <span><i class="dot dot-selected"></i>Selected</span>
          </div>
        </div>

        <div class="seat-grid-wrap" id="seatLayoutShell" data-type="<%= type %>" data-item-id="<%= item[type + '_id'] || item.hotel_id %>">
          <div class="seat-grid" id="seatMap"></div>
        </div>
        <p class="subtext" id="seatSelectionInfo">Loading selection map...</p>
      </div>

      <input type="hidden" name="seat_labels" id="seatLabelsInput" />
      <label><%= type === 'hotel' ? 'Selected Rooms Count' : 'Selected Seats Count' %>
        <input type="number" name="units" id="seatCountInput" min="1" value="0" readonly required />
      </label>

      <button class="btn btn-full" type="submit">Proceed to Payment</button>
    </form>
  </div>
</section>

<%- include('../partials/footer') %>
