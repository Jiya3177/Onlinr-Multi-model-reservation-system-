<%- include('../partials/header') %>

<section class="container page-section">
  <div class="section-head">
    <div>
      <p class="eyebrow">User Dashboard</p>
      <h1>Hello, <%= currentUser.full_name %></h1>
      <p class="subtext">Track your bookings, notifications, cancellations, and tickets.</p>
    </div>
  </div>

  <div class="stats-grid">
    <article class="card-glass stat-card"><h4><%= upcoming.length %></h4><p>Upcoming</p></article>
    <article class="card-glass stat-card"><h4><%= bookings.length %></h4><p>Total Bookings</p></article>
    <article class="card-glass stat-card"><h4>INR <%= totalSpent.toFixed(2) %></h4><p>Total Spend</p></article>
    <article class="card-glass stat-card"><h4><%= notifications.length %></h4><p>Notifications</p></article>
  </div>

  <div class="section-split">
    <article class="card-glass">
      <h3>Upcoming Trips</h3>
      <div class="result-grid-v2">
        <% if (!upcoming.length) { %>
          <p class="subtext">No upcoming trips.</p>
        <% } %>
        <% upcoming.forEach(b => { %>
          <article class="result-card-v2">
            <div class="result-head">
              <h3><%= b.booking_type.toUpperCase() %></h3>
              <span class="pill-badge"><%= b.booking_status %></span>
            </div>
            <p><strong><%= b.reservation_id %></strong></p>
            <p class="subtext">Date: <%= b.travel_date %></p>
            <div class="result-foot">
              <strong class="price-main">INR <%= b.total_price %></strong>
              <% if (b.booking_status === 'CONFIRMED') { %>
                <a class="btn btn-xs" href="/booking/ticket/<%= b.booking_id %>">Ticket</a>
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>
    </article>

    <article class="card-glass">
      <h3>Notifications</h3>
      <div class="notif-stack">
        <% if (!notifications.length) { %>
          <p class="subtext">No notifications available.</p>
        <% } %>
        <% notifications.forEach(n => { %>
          <div class="notif-item">
            <strong><%= n.title %></strong>
            <p><%= n.message %></p>
            <small><%= n.channel %> • <%= n.created_at %></small>
          </div>
        <% }) %>
      </div>
    </article>
  </div>

  <article class="card-glass">
    <h3>Booking History</h3>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Reservation</th><th>Type</th><th>Date</th><th>Price</th><th>Status</th><th>Payment</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% bookings.forEach(b => { %>
            <tr>
              <td><%= b.reservation_id %></td>
              <td><%= b.booking_type %></td>
              <td><%= b.travel_date %></td>
              <td>INR <%= b.total_price %></td>
              <td><%= b.booking_status %></td>
              <td><%= b.payment_status || 'PENDING' %></td>
              <td>
                <% if (b.booking_status === 'CONFIRMED') { %>
                  <a href="/booking/ticket/<%= b.booking_id %>">Ticket</a>
                <% } %>
                <% if (b.booking_status !== 'CANCELLED') { %>
                  <form class="inline-form" action="/booking/cancel/<%= b.booking_id %>" method="POST">
                    <button type="submit" class="text-link danger">Cancel</button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>
</section>

<%- include('../partials/footer') %>
