<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ORS - Multi-Modal Booking</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Syne:wght@600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
  <script defer src="/js/main.js"></script>
</head>
<body class="page-enter">
  <div class="bg-layer"></div>
  <header class="topbar">
    <div class="container nav-wrap">
      <a href="/" class="brand-link">
        <span class="brand-badge">ORS</span>
        <span class="brand-meta">
          <strong>Online Reservation System</strong>
          <small>Flight • Train • Bus • Hotel</small>
        </span>
      </a>

      <nav class="nav-row">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <% if (currentUser) { %>
          <a href="/dashboard">Dashboard</a>
          <form action="/auth/logout" method="POST" class="inline-form">
            <button type="submit" class="text-link">Logout</button>
          </form>
        <% } else { %>
          <a href="/auth/login">Login</a>
          <a href="/auth/register" class="btn btn-xs">Register</a>
        <% } %>
        <% if (currentAdmin) { %>
          <a href="/admin" class="pill">Admin</a>
        <% } else { %>
          <a href="/auth/admin/login" class="pill">Admin Login</a>
        <% } %>
      </nav>
    </div>
  </header>

  <% if (flash) { %>
    <section class="container toast-row">
      <div class="toast <%= flash.type === 'error' ? 'toast-error' : 'toast-success' %>"><%= flash.message %></div>
    </section>
  <% } %>

  <main class="main-shell">
