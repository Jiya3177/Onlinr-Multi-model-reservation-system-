<%- include('../partials/header') %>

<section class="container page-section">
  <div class="section-head">
    <div>
      <p class="eyebrow">Admin Payments</p>
      <h1>Payment & Refund Report</h1>
    </div>
  </div>

  <article class="card-glass">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Payment ID</th><th>User</th><th>Reservation</th><th>Type</th><th>Amount</th><th>Method</th><th>Txn</th><th>Status</th><th>Refund</th><th>Refund Status</th><th>Created</th>
          </tr>
        </thead>
        <tbody>
          <% payments.forEach(p => { %>
            <tr>
              <td><%= p.payment_id %></td>
              <td><%= p.full_name %></td>
              <td><%= p.reservation_id %></td>
              <td><%= p.booking_type %></td>
              <td>INR <%= p.amount %></td>
              <td><%= p.payment_method %></td>
              <td><%= p.transaction_ref %></td>
              <td><%= p.payment_status %></td>
              <td><%= p.refund_amount ? ('INR ' + p.refund_amount) : '-' %></td>
              <td><%= p.refund_status || '-' %></td>
              <td><%= p.created_at %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>
</section>

<%- include('../partials/footer') %>
